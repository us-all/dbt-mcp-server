{
  "name": "@us-all/dbt-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.us-all/dbt",
  "description": "dbt MCP server — manifest, run results, sources, freshness, coverage, and DQ result tables in one stdio MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dbt-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "presmoke": "pnpm run build",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@us-all/mcp-toolkit": "^1.2.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.2"
  },
  "peerDependencies": {
    "@google-cloud/bigquery": "^7.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/bigquery": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@google-cloud/bigquery": "^7.9.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.14"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/us-all/dbt-mcp-server"
  },
  "license": "MIT"
}
